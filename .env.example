# Never commit the filled-in .env file. Keep it local to the machine that runs the scanner.
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=

# Use a dedicated, low-balance wallet. This value is required even in observation mode
# because the scanner validates its configuration before startup.
WALLET_PRIVATE_KEY=

# Safe default: do not sign or broadcast transactions.
ENABLE_LIVE_TRADING=0

# Keep the dashboard private unless a separate authenticated reverse proxy is configured.
DASHBOARD_HOST=127.0.0.1
