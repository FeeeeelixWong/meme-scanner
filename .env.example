# Never commit the filled-in .env file. Keep secrets only on the local machine.
# replay: built-in fixtures only; observe: read market data; live: experimental signing path.
MEME_SCANNER_MODE=replay

# Required only for MEME_SCANNER_MODE=observe or live.
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=

# Required only for MEME_SCANNER_MODE=live. Never use a primary wallet or expose
# this value through a shell history, screenshot, issue, or chat transcript.
WALLET_PRIVATE_KEY=

# Second explicit gate for live mode. It must remain 0 for replay and observe.
ENABLE_LIVE_TRADING=0

# Keep the dashboard private unless a separate authenticated reverse proxy is configured.
DASHBOARD_HOST=127.0.0.1
